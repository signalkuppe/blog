<style is:global>
	html {
		--color: black;
		--background: white;
		--accent: blue;
		--grey: #e2e2e2;
	}

	.dark {
		--color: white;
		--background: black;
		--grey: #222;
	}

	body {
		font-size: clamp(1.2rem, 2vw, 1.8rem);
		color: var(--color);
		background: var(--background);
	}

	h1 {
		font-size: clamp(1.5rem, 9vw, 4rem);
		font-weight: 900;
		letter-spacing: -0.03em;
	}

	strong {
		font-weight: 700;
	}
</style>
