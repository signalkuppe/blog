<style is:global>
	html {
		--color: black;
		--background: white;
		--accent: #0077cc;
		--grey: #e2e2e2;
		font-size: 100%;
		scrollbar-gutter: stable;
	}

	.dark {
		--color: white;
		--background: black;
		--grey: #111;
	}

	body {
		font-size: 1rem;
		color: var(--color);
		background: var(--background);
		padding: 1.5rem;
	}

	:is(h1, h2, h3, h4, h5, h6) {
		font-weight: 900;
		letter-spacing: -0.03em;
	}

	h1 {
		font-size: 2.5rem;
	}

	strong {
		font-weight: 700;
	}

	a {
		font-weight: 700;
		color: var(--accent);
	}

	a:hover {
		text-decoration: underline;
	}

	summary {
		font-weight: 700;
		color: var(--accent);
	}

	details[open] summary {
		margin-bottom: 1.5rem;
	}

	p {
		margin-bottom: 1.5rem;
	}

	summary {
		cursor: pointer;
	}

	@media screen and (min-width: 1180px) {
		html {
			font-size: 140%;
		}
	}
</style>
