---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  photo: CollectionEntry<"portfolio">;
  imageProps?: any;
}

const { photo, imageProps } = Astro.props;
const cardMaxWidth = Math.min(photo.data.photo.src.width, 720);
const cardWidths = [240, 320, 400, 480, 560, 640, 720, cardMaxWidth]
  .filter((width) => width <= cardMaxWidth)
  .filter((width, index, arr) => arr.indexOf(width) === index)
  .sort((a, b) => a - b);
---

<article>
  <aside>
    <Image
      src={photo.data.photo.src}
      alt={photo.data.photo.alt}
      width={cardMaxWidth}
      widths={cardWidths}
      sizes="(max-width: 30rem) calc(100vw - 3rem), (max-width: 60rem) calc(50vw - 3rem), (max-width: 80rem) calc(33vw - 3rem), calc(25vw - 3rem)"
      quality={55}
      {...imageProps}
    />
  </aside>

  <div class="caption">
    <time datetime={photo.data.date.toISOString().slice(0, 19)}>
      <span class="visually-hidden">Scattata il </span>
      {photo.data.date.toLocaleDateString("it-IT")}
    </time>
    <h2 aria-hidden="true">
      {photo.data.title}
    </h2>
  </div>
</article>

<style media="screen">
  article {
    width: 100%;
    border: 1px solid var(--surfaceAccent);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
  }

  article:hover {
    border-color: var(--accent);
  }

  .caption {
    line-height: 1;
    width: 100%;
    padding: 0.75rem 0;
  }

  aside {
    overflow: hidden;
  }

  time {
    font-size: 0.75rem;
    display: block;
    padding-bottom: 0.5rem;
    font-weight: 400;
  }

  h2 {
    font-size: 1rem;
    line-height: 1.2;
    color: inherit;
  }

  img {
    grid-area: 1 / 1;
    transition: transform 0.2s cubic-bezier(0.075, 0.82, 0.165, 1);
    display: block;
    border-radius: 5px;
    background: var(--surfaceAccent);
  }

  @media screen and (width > 60rem) {
    time {
      font-size: 0.85rem;
    }

    h2 {
      font-size: 1rem;
    }
  }
</style>
