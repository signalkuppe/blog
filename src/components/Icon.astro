---
interface Props {
	name: string
	size?: string
	class?: string
	strokeWidth?: string
}

const { name, size, class: className, strokeWidth } = Astro.props
const { default: innerHTML } = await import(`../icons/${name}.svg?raw`)
let finalHtml
if (size) {
	finalHtml = innerHTML
		.replace(/width="(\d+)"/, `width="${size}"`)
		.replace(/height="(\d+)"/, `height="${size}"`)
}

if (className) {
	finalHtml = finalHtml.replace('<svg', `<svg class="${className}"`)
}

if (strokeWidth) {
	finalHtml = finalHtml.replace(/stroke-width="(\d+)"/, `stroke-width="${strokeWidth}"`)
}
---

<Fragment set:html={finalHtml} />

<script></script>
