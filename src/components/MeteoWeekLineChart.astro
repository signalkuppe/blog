---
const { data } = Astro.props;
---

<canvas class="meteo-week-chart" data-points={JSON.stringify(data)}></canvas>

<script>
  // @ts-nocheck
  import { WEATHER_CONSTANTS } from "../constants";
  import "chartjs-adapter-dayjs-4/dist/chartjs-adapter-dayjs-4.esm";
  import { Chart, registerables } from "chart.js";
  import { getCssVar } from "../lib/utils";
  Chart.register(...registerables);

  const canvas = document.querySelectorAll(".meteo-week-chart");
  // On mobile the chart is a single column, so a wide ratio looks stretched.
  const mobile = window.matchMedia("(max-width: 40rem)");
  let charts = [];

  function drawChart(ctx, dataset) {
    const chart = new Chart(ctx, {
      type: "line",
      data: {
        datasets: [
          {
            data: dataset,
            borderColor: getCssVar(WEATHER_CONSTANTS.GRAPH_LINE_COLOR),
            backgroundColor: "none",
            borderWidth: 1.5,
            tension: 0.1,
            pointRadius: 0,
          },
        ],
      },
      options: {
        responsive: true,
        aspectRatio: mobile.matches ? 1.4 : 2.4,
        interaction: { mode: "index", intersect: false },
        plugins: {
          legend: false,
          tooltip: {
            callbacks: {
              label: (ctx) => `${ctx.formattedValue}`,
            },
          },
        },
        scales: {
          x: {
            type: "time",
            time: {
              parser: "YYYY-MM-DD HH:mm",
              tooltipFormat: "DD/MM HH:mm",
              unit: "day", // Granularità giornaliera sui 7 giorni
              displayFormats: {
                day: "DD/MM",
              },
            },
            ticks: {
              maxRotation: 0,
              autoSkip: true,
            },
            grid: {
              color: getCssVar(WEATHER_CONSTANTS.GRAPH_GRID_COLOR),
            },
          },
          y: {
            grid: {
              color: getCssVar(WEATHER_CONSTANTS.GRAPH_GRID_COLOR),
            },
            ticks: {
              callback: function (value) {
                return value;
              },
            },
          },
        },
      },
    });
    charts.push(chart);
  }

  function init() {
    if (charts.length) {
      charts.forEach((chart) => chart.destroy());
    }
    canvas.forEach((canva) => {
      const ctx = canva.getContext("2d");
      const dataset = JSON.parse(canva.getAttribute("data-points"));
      drawChart(ctx, dataset);
    });
  }

  init();

  document.addEventListener("theme-change", () => {
    // otherwise getCssVar is not re-evaluated
    init();
  });

  // Re-init when crossing the mobile breakpoint so the aspect ratio updates.
  mobile.addEventListener("change", () => init());
</script>
