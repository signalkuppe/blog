---
import Spinner from "./Spinner.astro";

interface Props {
  cover: {
    src: ImageMetadata;
    alt: string;
  };
  // Precomputed getImage() result, generated in the page so the same responsive
  // set can be preloaded in <head> for a faster LCP.
  hero: any;
}

const { cover, hero } = Astro.props;
---

<div class="cover">
  <div class="spinner-container" aria-live="polite">
    <Spinner size="2rem" />
    <span>Carico la copertina...</span>
  </div>
  <img
    src={hero.src}
    srcset={hero.srcSet.attribute}
    sizes="100vw"
    alt={cover.alt}
    width={hero.attributes.width}
    height={hero.attributes.height}
    loading="eager"
    decoding="sync"
    fetchpriority="high"
    class="cover-picture"
  />
  <p aria-hidden="true" class="caption">{cover.alt}</p>
</div>

<style media="screen">
  .cover {
    width: 100%;
    background: linear-gradient(-45deg, var(--surface), var(--surfaceAccent));
    background-size: 400% 400%;
    display: grid;
    position: relative;
  }

  .spinner-container {
    grid-area: 1/1;
    z-index: 0;
    font-size: 0.85rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  :global(.cover-picture) {
    display: grid;
    grid-area: 1/1;
    z-index: 1;
  }

  img {
    object-fit: cover;
    width: 100%;
  }

  .cover,
  img {
    aspect-ratio: 4 / 3;
  }

  .caption {
    font-size: 1rem;
    grid-area: 1/1;
    z-index: 2;
    background: rgba(0, 0, 0, 0.7);
    color: var(--textAccent);
    padding: 0.25rem 0.85rem;
    place-self: end;
    font-weight: var(--font-bolder);
    background: var(--surface);
    transform: translate(-0.5rem, -0.5rem);
  }

  .cover.is-loaded .spinner-container {
    display: none;
  }

  img.desktop {
    display: none;
  }

  @keyframes gradient {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .cover {
      animation: gradient 2s ease infinite;
    }
  }

  @media screen and (width > 60rem) {
    .cover,
    img {
      aspect-ratio: 16 / 10;
    }
    .caption {
      font-size: 2rem;
      padding: 0.75rem 1.5rem;
      transform: translate(-1rem, -1rem);
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const cover = document.querySelector(".cover");
    if (!cover) return;

    const image = cover.querySelector("img");
    if (!image) return;

    const setLoaded = () => cover.classList.add("is-loaded");

    if (image.complete && image.naturalWidth > 0) {
      setLoaded();
      return;
    }

    image.addEventListener("load", setLoaded, { once: true });
    image.addEventListener("error", setLoaded, { once: true });
  });
</script>
