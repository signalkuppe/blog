---
interface Props {
	Element?: string
	children: any
	class?: string
}

const { Element = 'span', class: className, ...props } = Astro.props
---

<Element class:list={['sr-only', className]} {...props}><slot /></Element>

<style>
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}
</style>
