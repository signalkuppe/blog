---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import SearchIcon from "../icons/Search.svg";

const posts = await getCollection("posts");
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const dataset = await Promise.all(
  posts.map(async (post) => {
    const thumbnail = await getImage({
      src: post.data.cover.src,
      width: 120,
      height: 120,
      fit: "cover",
      format: "avif",
      quality: 45,
    });

    return {
      title: post.data.title,
      slug: post.slug,
      tags: post.data.tags || [],
      date: post.data.date.toISOString(),
      description: post.data.description,
      image: thumbnail.src,
    };
  }),
);
---

<form id="search-form" role="search" data-posts={JSON.stringify(dataset)}>
  <label for="search-input" class="visually-hidden">Cerca un'uscita</label>
  <input
    type="text"
    id="search-input"
    autocomplete="off"
    role="combobox"
    aria-autocomplete="list"
    aria-haspopup="listbox"
  />
  <SearchIcon aria-hidden="true" />
  <div id="results" role="listbox">
    <div id="arrow" aria-hidden="true"></div>
  </div>
</form>

<style media="screen">
  form {
    display: grid;
    width: 12rem;
    min-height: 2.25rem;
  }

  form svg {
    height: 1em;
    grid-area: 1 / 1;
    transform: translate(0.75rem, 0.75rem);
  }

  form input {
    grid-area: 1 / 1;
    padding: 0.5rem;
    text-indent: 2rem;
    display: block;
    width: 100%;
    color: var(--text);
  }

  @media screen and (width < 24rem) {
    form {
      width: 9rem;
    }
  }

  #results {
    --borderColor: var(--accent);
    --borderWidth: var(--focusOutlineWidth);
    width: max-content;
    position: fixed;
    top: 0;
    left: 0;
    background: var(--surface);
    padding: 1rem;
    display: none;
    border: var(--borderWidth) solid var(--borderColor);
    border-radius: 15px;
    max-width: min(40ch, 75vw);

    z-index: 1000;
  }

  #arrow {
    position: absolute;
    background: var(--surface);
    width: 16px;
    height: 16px;
    transform: rotate(45deg) translateY(-0.4rem);
    border-color: var(--borderColor);
    border-top-width: var(--borderWidth);
    border-top-style: solid;
    border-left-width: var(--borderWidth);
    border-left-style: solid;
  }

  @media screen and (orientation: portrait) {
    #arrow {
      transform: rotate(45deg) translateY(-0.5rem);
    }
  }

  :global(#results ul) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  :global(#results a) {
    display: flex;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--text);
    padding: 0.5rem;
    margin: -0.5rem;
    border-radius: 8px;
    transition: background-color 0.15s ease;
    max-width: 350px;
  }

  :global(#results a:hover),
  :global(#results a:focus) {
    background-color: var(--surfaceAccent);
    outline: none;
  }

  :global(#results a.highlighted) {
    background-color: var(--surfaceAccent);
  }

  :global(#results img) {
    background: var(--surfaceAccent);
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 4px;
  }

  :global(#results div) {
    display: flex;
    flex-direction: column;
  }

  :global(#results p) {
    font-size: 0.8rem;
  }

  :global(#results div p:first-child) {
    font-weight: var(--font-bold);
    font-size: 0.8rem;
    color: var(--textAccent);
    line-height: 1.4;
  }
  :global(#results div p:nth-child(2)) {
    font-size: 0.6rem;
  }

  :global(#results .results-footer) {
    font-size: 0.7rem;
    color: var(--textLight);
    text-align: center;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--surfaceAccent);
  }
</style>
