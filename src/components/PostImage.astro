---
import { Image } from "astro:assets";

interface Props {
  src: ImageMetadata;
  alt: string;
}

const { src, alt } = Astro.props;
const inlineMaxWidth = Math.min(src.width, 1400);
const inlineSizes =
  "(max-width: 720px) calc(100vw - 3rem), (max-width: 1200px) 90vw, 1100px";
const inlineWidths = [720, 1100, 1400].filter((width) => width <= inlineMaxWidth);
---

<picture>
  <Image
    src={src}
    alt={alt}
    width={inlineMaxWidth}
    sizes={inlineSizes}
    widths={inlineWidths}
    format="webp"
    quality={65}
    priority
  />
</picture>
{
  alt && (
    <p class="img-caption" aria-hidden="true">
      {alt}
    </p>
  )
}

<style>
  .img-caption {
    font-size: 0.75rem;
    margin-top: 0.4rem;
    text-align: right;
  }
</style>
