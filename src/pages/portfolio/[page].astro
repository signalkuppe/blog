---
import "photoswipe/dist/photoswipe.css";
import { getImage } from "astro:assets";
import PageTitle from "../../components/PageTitle.astro";
import PhotoCard from "../../components/PhotoCard.astro";
import { headPageTitle, portfolioPhotoSlug } from "../../lib/utils";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Pager from "../../components/Pager.astro";
import PhotoDisclaimer from "../../components/PhotoDisclaimer.astro";
import { siteSlogan } from "../../constants";
import {
  cloudinaryResponsiveImage,
  getCloudinaryPortfolioOriginalUrl,
  getCloudinaryPortfolioViewUrl,
} from "../../lib/cloudinary-originals";

export async function getStaticPaths({ paginate }) {
  const photos = await getCollection("portfolio");
  photos.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return paginate(photos, {
    pageSize: 12,
  });
}

interface Props {
  page?: any;
}

const { page } = Astro.props;

let pageTitle = "Portfolio";

if (page.currentPage > 1) {
  pageTitle = `${pageTitle}, pagina ${page.currentPage}`;
}

const description = "Una raccolta delle mie foto più belle";
const galleryItems = await Promise.all(
  page.data.map(async (photo) => {
    const cloudinaryView = getCloudinaryPortfolioViewUrl(photo.id);
    const lightboxMaxWidth = Math.min(photo.data.photo.src.width, 2400);
    const lightboxWidths = [720, 1080, 1440, 1800, 2200, lightboxMaxWidth]
      .filter((width) => width <= lightboxMaxWidth)
      .filter((width, itemIndex, arr) => arr.indexOf(width) === itemIndex)
      .sort((a, b) => a - b);
    const lightbox = cloudinaryView
      ? {
          ...cloudinaryResponsiveImage(cloudinaryView, lightboxWidths, "auto"),
          attributes: {
            width: photo.data.photo.src.width,
            height: photo.data.photo.src.height,
          },
          sizes: "100vw",
        }
      : await getImage({
          src: photo.data.photo.src,
          width: 2000,
          format: "avif",
          quality: 55,
        });
    const cloudinaryDownload = getCloudinaryPortfolioOriginalUrl(photo.id);
    const download = cloudinaryDownload
      ? { src: cloudinaryDownload }
      : await getImage({
          src: photo.data.photo.src,
          format: "jpg",
          width: photo.data.photo.src.width,
          quality: 90,
        });

    return { photo, lightbox, download };
  }),
);
---

<Layout
  title={headPageTitle(pageTitle, siteSlogan)}
  description={description}
  ogImage="/og-image.jpg"
>
  <div class="cage">
    <PageTitle subTitle={description}>{pageTitle}</PageTitle>
  </div>

  <div class="container">
    <ul id="photo-gallery">
      {
        galleryItems.map(({ photo, lightbox, download }, i) => {
          return (
            <li>
              <a
                aria-label={photo.data.title}
                href={`/${portfolioPhotoSlug(photo)}`}
                data-download={download.src}
                data-pswp-src={lightbox.src}
                data-pswp-srcset={lightbox.srcset}
                data-pswp-sizes={lightbox.sizes}
                data-pswp-width={lightbox.attributes.width}
                data-pswp-height={lightbox.attributes.height}
              >
                <PhotoCard photo={photo} imageProps={{ priority: i <= 5 }} />
              </a>
            </li>
          );
        })
      }
    </ul>
    <div class="cage bottom">
      <nav aria-label="Pagine">
        <Pager page={page} />
      </nav>
      <p class="disclaimer"><PhotoDisclaimer /></p>
    </div>
  </div>
</Layout>

<script>
  //@ts-nocheck
  import { emitter } from "../../lib/utils";
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import PhotoSwipe from "photoswipe";

  document.addEventListener("DOMContentLoaded", () => {
    emitter.emit("header-background-change", true);
    const lightbox = new PhotoSwipeLightbox({
      gallery: "#photo-gallery",
      children: "a",
      pswpModule: PhotoSwipe,
      showHideAnimationType: "zoom",
      showAnimationDuration: 500,
      hideAnimationDuration: 500, // Match durations for a smoother feel
      bgOpacity: 0.9, // Set background opacity here
    });
    lightbox.on("uiRegister", function () {
      lightbox.pswp.ui.registerElement({
        name: "download-button",
        order: 8,
        isButton: true,
        tagName: "a",
        html: {
          isCustomSVG: true,
          inner:
            '<path d="M20.5 14.3 17.1 18V10h-2.2v7.9l-3.4-3.6L10 16l6 6.1 6-6.1ZM23 23H9v2h14Z" id="pswp__icn-download"/>',
          outlineID: "pswp__icn-download",
        },

        onInit: (el, pswp) => {
          el.setAttribute("download", "");
          el.setAttribute("target", "_blank");
          el.setAttribute("rel", "noopener");

          pswp.on("change", () => {
            el.href = pswp.currSlide.data.element.getAttribute("data-download");
          });
        },
      });
      lightbox.pswp.ui.registerElement({
        name: "custom-caption",
        order: 9,
        isButton: false,
        appendTo: "root",
        html: "Caption text",
        onInit: (el, pswp) => {
          lightbox.pswp.on("change", () => {
            const currSlideElement = lightbox.pswp.currSlide.data.element;
            let captionHTML = "";
            if (currSlideElement) {
              captionHTML = currSlideElement
                .querySelector("img")
                .getAttribute("alt");
            }
            el.innerHTML = captionHTML || "";
          });
        },
      });
    });

    lightbox.init();
  });
</script>

<style media="screen">
  .container {
    --space: 1.5rem;
    padding: var(--space);
  }
  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space);
  }

  a {
    text-decoration: none;
    display: block;
  }

  a:focus-visible {
    outline: none;
  }

  .bottom {
    margin: 8rem auto 4rem auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .disclaimer {
    margin-top: 3rem;
    max-width: 70ch;
    font-size: 0.75rem;
  }

  @media screen and (width > 30rem) {
    ul {
      display: block;
      columns: 2;
      column-gap: var(--space);
    }
    li {
      margin-bottom: var(--space);
      break-inside: avoid;
    }
  }

  @media screen and (width > 60rem) {
    ul {
      columns: 3;
    }
  }

  :global(.pswp__custom-caption) {
    background: black;
    font-size: 16px;
    color: white;
    width: fit-content;
    padding: 2px 8px;
    border-radius: 4px;
    position: absolute;
    left: 50%;
    bottom: 16px;
    transform: translateX(-50%);
    text-align: center;
  }
</style>
